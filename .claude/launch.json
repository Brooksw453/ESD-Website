{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "website",
      "runtimeExecutable": "C:/Program Files/nodejs/node.exe",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const mime={'html':'text/html','css':'text/css','js':'application/javascript','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml','mp3':'audio/mpeg','xml':'application/xml','json':'application/json','ico':'image/x-icon'};const root=process.cwd();http.createServer((req,res)=>{let u=decodeURIComponent(req.url.split('?')[0]);let p=path.join(root,u==='/'?'index.html':u);fs.readFile(p,(e,d)=>{if(e){res.writeHead(404);res.end('Not found');return;}const ext=path.extname(p).slice(1);res.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream'});res.end(d);});}).listen(3000,()=>console.log('Server on 3000'));"],
      "port": 3000
    }
  ]
}
